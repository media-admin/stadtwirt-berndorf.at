{
  "name": "custom-wordpress-theme",
  "version": "1.5.0",
  "type": "module",
  "description": "Custom WordPress Theme from Figma",
  "scripts": {
    "dev": "node scripts/vite-dev.mjs",
    "dev:stop": "node -e \"try{require('fs').unlinkSync('cms/wp-content/themes/custom-theme/assets/hot')}catch(e){}\"",
    "build": "vite build && vite build --config vite.config.blocks.js",
    "build:staging": "NODE_ENV=staging vite build && NODE_ENV=staging vite build --config vite.config.blocks.js",
    "build:production": "NODE_ENV=production vite build && NODE_ENV=production vite build --config vite.config.blocks.js",
    "watch": "vite build --watch & vite build --config vite.config.blocks.js --watch",
    "preview": "vite preview",
    "build:theme": "vite build",
    "build:blocks": "vite build --config vite.config.blocks.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:e2e": "playwright test tests/e2e",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.js",
    "test:performance": "playwright test tests/e2e/performance.spec.js",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.js",
    "vrt:ref": "backstop reference --config=backstop.json",
    "vrt:test": "backstop test --config=backstop.json",
    "vrt:approve": "backstop approve --config=backstop.json",
    "vrt:report": "backstop openReport --config=backstop.json",
    "lighthouse": "lhci autorun",
    "test:all": "npm run test && npm run lighthouse",
    "deploy:staging": "npm run build:staging && node scripts/deploy-staging.js",
    "deploy:production": "npm run build:production && node scripts/deploy-production.js"
  }
}
